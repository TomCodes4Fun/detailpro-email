# Copy this file to .env and fill in values.

# ── Database (Render managed Postgres) ──────────────────────────────────────
# Render injects DATABASE_URL automatically when you link a Postgres instance.
# For local dev, create a local Postgres DB and paste the connection string here.
DATABASE_URL=postgresql://user:password@localhost:5432/detailpro

# ── Auth ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER commit this value to git.
JWT_SECRET=

# ── SMTP (email sending) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=no-reply@example.com
FROM_NAME=DetailPro CRM

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins (your Netlify URL).
ALLOWED_ORIGINS=https://your-app.netlify.app

# Optional API key for the /api/send-email endpoint.
EMAIL_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# Leave unset on Render — it injects PORT automatically.
PORT=3333

# --- Database + auth (multi-tenant accounts) ---
# Render gives you this automatically when you attach a Postgres database —
# copy it from the database's "Internal Connection String" / "External
# Connection String" in the Render dashboard.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Long random string used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
